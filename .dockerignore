# ===================================================
# .dockerignore - Optimized for Next.js + Docker
# Purpose: Prevent unnecessary files from being copied into Docker images
# Result: Smaller images, faster builds, improved security
# ===================================================

# ========== Dependencies ==========
# Never copy node_modules from host - install fresh in container
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ========== Build Artifacts ==========
# These are generated during the Docker build process
.next
out
dist
build
.vercel

# ========== Testing & Coverage ==========
# Test files and coverage reports are not needed in production
coverage
.nyc_output
*.test.js
*.spec.js
test/
tests/
__tests__/

# ========== Environment Variables ==========
# CRITICAL: Never include any .env files in Docker images
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*

# ========== OS & System Files ==========
# macOS system files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows system files
ehthumbs.db
Thumbs.db

# ========== IDE & Editor Files ==========
# Editor configurations not needed at runtime
.idea/
.vscode/
*.swp
*.swo
*~

# ========== Version Control ==========
# Git repository is unnecessary in the image
.git
.gitignore
.gitattributes
.husky/

# ========== Docker Files ==========
# Docker build files themselves shouldn't be in the image
Dockerfile*
Containerfile*
.dockerignore
docker-compose*.yml
docker-compose*.yaml

# ========== Documentation ==========
# Docs are for developers, not production runtime
README.md
*.md
LICENSE
CHANGELOG.md
CONTRIBUTING.md

# ========== Cache & Temp Files ==========
# Various cache directories that may exist
.cache/
.parcel-cache/
tmp/
temp/
.tmp/
.temp/

# ========== Logs ==========
# Log files shouldn't be in the image
*.log
logs/

# ========== Optional: Keep Examples ==========
# Uncomment if you want to keep .env.example in the image
# !.env.example