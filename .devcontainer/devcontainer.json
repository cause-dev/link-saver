{
  "name": "Link Saver — Frontend (Next.js)",
  "dockerComposeFile": [
    "./compose.yml"
  ],
  "service": "frontend",
  "workspaceFolder": "/app",
  "shutdownAction": "stopCompose",
  "overrideCommand": false,
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "dsznajder.es7-react-js-snippets",
        "formulahendry.auto-rename-tag",
        "mikestead.dotenv"
      ],
      "settings": {
        "[typescript]": {
          "editor.tabSize": 2
        },
        "[typescriptreact]": {
          "editor.tabSize": 2
        },
        "[json]": {
          "editor.tabSize": 2
        },
        "[css]": {
          "editor.tabSize": 2
        },
        "[markdown]": {
          "files.trimTrailingWhitespace": false
        },
        "tailwindCSS.emmetCompletions": true,
        "emmet.includeLanguages": {
          "typescriptreact": "html"
        },
        "eslint.workingDirectories": [
          "/app"
        ],
        "eslint.validate": [
          "javascript",
          "javascriptreact",
          "typescript",
          "typescriptreact"
        ],
        "files.exclude": {
          "**/.next": true,
          "**/node_modules": true
        },
        "files.watcherExclude": {
          "**/node_modules/**": true,
          "**/.next/**": true
        },
        "search.exclude": {
          "**/node_modules": true,
          "**/.next": true
        },
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true,
        "files.trimFinalNewlines": true
      }
    }
  },
  "forwardPorts": [
    3000
  ],
  "portsAttributes": {
    "3000": {
      "label": "Next.js",
      "onAutoForward": "openBrowser"
    }
  },
  "remoteUser": "root"
}